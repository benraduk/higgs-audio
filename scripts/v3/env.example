# Copy to scripts/v3/.env and adjust paths on your GPU PC.
# cp scripts/v3/env.example scripts/v3/.env

# Hugging Face (for hf download)
# HF_TOKEN=hf_xxxxxxxx

# Model
MODEL_ID=bosonai/higgs-audio-v3-tts-4b
MODEL_LOCAL_DIR=

# SGLang-Omni clone location (default: sibling directory to higgs-audio)
# SGLANG_OMNI_DIR=/path/to/sglang-omni

# Server
SERVE_PORT=8000
SERVE_HOST=0.0.0.0

# Optional: Boson cloud API smoke test
# BOSON_API_KEY=bai-xxxx
